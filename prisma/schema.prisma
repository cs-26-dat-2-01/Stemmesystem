// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  runtime  = "deno"
}

datasource db {
  provider = "sqlite"
}

// Create database file. -------------------------------
// To-do: remove AUTOINCREMENT as it does not fit
// the use case. (See https://sqlite.org/autoinc.html)
// -----------------------------------------------------
model User {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String

  createdPolls     Poll[]
  eligibleVoterFor PollEligibleVoter[]
}

model Poll {
  id             Int       @id @default(autoincrement())
  title          String?
  description    String?
  voteStatus     String    @default("draft")
  createdBy      Int
  creator        User      @relation(fields: [createdBy], references: [id])
  createdAt      DateTime  @default(now())
  startsAt       DateTime?
  endsAt         DateTime?
  pollVisibility String?
  ballotPrivacy  String?
  showTopN       Int?
  ballotLimit    Int?
  useBuffer      Int?

  // Per-poll RSA-keypair for blind signing (RFC 9474).
  blindRsaPublicKey  String?
  blindRsaPrivateKey String?
  blindRsaKeyBits    Int     @default(2048)

  // Tamper-evidence at poll-close: commitment over finalChainHash + tally + meta get signed by FreeTSA.
  closeCommitment     String?
  closeTimestampQuery Bytes?
  closeTimestampToken Bytes?
  closedAt            DateTime?

  options        PollOption[]
  eligibleVoters PollEligibleVoter[]
  votes          Vote[]
  pendingVotes   PendingVote[]
  auditLogs      AuditLog[]
}

model PollEligibleVoter {
  pollId       Int
  poll         Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  userId       Int
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  votesAllowed Int
  signaturesIssued Int @default(0)

  @@id([pollId, userId])
}

model PollOption {
  id           Int     @id @default(autoincrement())
  pollId       Int
  poll         Poll    @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionText   String?
  displayOrder Int     @default(0)

  votes Vote[]
  pendingVotes PendingVote[]
}

model PendingVote {
  id           String @id
  pollId       Int
  poll         Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollOptionId Int
  option       PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  uuid         String @unique
  signature    String @unique
}

model Vote {
  id           String     @id
  pollId       Int
  poll         Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollOptionId Int
  option       PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  timestamp    DateTime   @default(now())
  chainPosition Int
  previousHash String
  currentHash  String     @unique
  // Blind-signature after Finalize 
  signature    String

  @@unique([pollId, chainPosition])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  action    String
  timestamp DateTime @default(now())
  details   String?

  polls Poll[]
}
