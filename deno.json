{
  "nodeModulesDir": "auto",
  "exclude": [
    "node_modules",
    "dist"
  ],
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "deno.ns", "esnext"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "allowJs": true
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.9",
    "@panva/jose": "jsr:@panva/jose@^6.2.2"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "include": ["camelcase"]
    }
  }
}
